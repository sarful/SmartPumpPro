MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pumppilot?retryWrites=true&w=majority
NEXTAUTH_SECRET=replace-with-32-plus-char-secret
MOBILE_JWT_SECRET=replace-with-32-plus-char-mobile-jwt-secret
ESP32_DEVICE_SECRET=replace-with-long-random-device-secret
CRON_SECRET=replace-with-long-random-cron-secret

# Required for hosted web callbacks / production runtime
NEXTAUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Optional mobile/runtime tuning
MOBILE_MAX_SESSIONS=5

# Initial setup seed values
SEED_MASTER_USERNAME=master
SEED_MASTER_PASSWORD=ChangeMe123!
SEED_DEMO_DATA=false

