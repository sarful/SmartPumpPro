{
  "name": "smartpump-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/env-check.js --mode=dev && next dev",
    "dev:nodemon": "nodemon",
    "build": "node scripts/env-check.js --mode=build && next build",
    "start": "node scripts/env-check.js --mode=start && next start",
    "lint": "eslint",
    "test": "node --require ./tests/helpers/register.cjs ./tests/run-tests.cjs",
    "typecheck": "tsc --noEmit",
    "release:validate": "npm test && npm run typecheck && npm run lint -- . && npm run install:check && npm run build",
    "auth:unlock": "node scripts/unlock-auth.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:setup": "node scripts/setup.js",
    "install:check": "node scripts/env-check.js --mode=build && node scripts/install-check.js",
    "package:codecanyon": "node scripts/prepare-codecanyon.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "mongoose": "^9.2.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "nodemon": "^3.1.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
